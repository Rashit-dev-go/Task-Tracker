# Task Tracker Environment Configuration

# Test Environment
TEST_ENV=test
CI=false

# Storage Configuration (for testing)
TASK_TRACKER_DATA_DIR=./testdata/temp
TASK_TRACKER_DATA_FILE=./testdata/temp/tasks.json

# Performance Test Settings
PERFORMANCE_TASK_COUNT=1000
PERFORMANCE_TIMEOUT_MS=2000

# Coverage Settings
COVERAGE_PROFILE=coverage.out
COVERAGE_HTML=coverage.html

# Logging
LOG_LEVEL=info
VERBOSE_TEST=false
